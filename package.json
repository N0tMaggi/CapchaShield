{
  "name": "captchashield",
  "version": "0.1.0",
  "description": "Customizable Cloudflare Turnstile modal with cookie-based skip logic for web apps.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "typescript",
    "web",
    "library",
    "captcha",
    "bot-protection",
    "turnstile",
    "modal"
  ],
  "author": "N0tMaggi",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.0.9",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "globals": "^15.14.0",
    "jsdom": "^27.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
